# AI provider
OPENAI_API_KEY=your_openai_api_key_here

# Optional: disable noisy OpenAI Agents tracing in restricted networks (default is disabled)
# HIPAA_AGENT_ENABLE_TRACING=1

# Optional: override where session snapshots are stored on disk
# HIPAA_AGENT_DATA_DIR=/absolute/path/to/.hipaa-agent-data

# GitHub App (recommended: Vercel-style private repo access + PR creation)
# 1) Create a GitHub App and set its callback URL to:
#    http://localhost:3001/api/github/callback
# 2) Set these env vars on the backend:
GITHUB_APP_SLUG=your-github-app-slug
GITHUB_APP_ID=123456
# Option A: paste the private key (use \n for newlines)
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Option B: or point to a PEM file
# GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/private-key.pem
GITHUB_APP_STATE_SECRET=replace_with_a_long_random_string
HIPAA_AGENT_FRONTEND_URL=http://localhost:3000

# Optional: for GitHub Enterprise Server
# GITHUB_API_BASE_URL=https://api.github.your-company.com
